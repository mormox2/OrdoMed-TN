{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "npm run generate:medications",
    "dev": "vite --port=3000 --host=0.0.0.0",
    "generate:medications": "node scripts/convert_amm_xlsx_to_json.cjs && node scripts/generate_dosage_templates.cjs && node scripts/generate_interactions.cjs",
    "prebuild": "node scripts/convert_amm_xlsx_to_json.cjs && node scripts/generate_dosage_templates.cjs && node scripts/generate_interactions.cjs",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test:classification": "node --test tests/regulatory-classification.test.cjs",
    "pretest:templates": "node scripts/generate_dosage_templates.cjs",
    "test:templates": "tsx --test tests/dosage-templates.test.ts",
    "test:search": "tsx --test tests/medicine-search.test.ts",
    "test:clinical": "tsx --test tests/clinical-template-evaluator.test.ts",
    "check": "npm run lint && npm run test:classification && npm run test:templates && npm run test:search && npm run test:clinical && npm run build"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@supabase/supabase-js": "^2.52.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
