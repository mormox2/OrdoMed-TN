rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function userPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function invitationPath(email) {
      return /databases/$(database)/documents/secretaryInvitations/$(email);
    }

    function prescriptionPath(prescriptionId) {
      return /databases/$(database)/documents/prescriptions/$(prescriptionId);
    }

    function patientPath(patientId) {
      return /databases/$(database)/documents/patients/$(patientId);
    }

    function hasUserProfile(uid) {
      return isSignedIn() && exists(userPath(uid));
    }

    function getUserDoc(uid) {
      return get(userPath(uid)).data;
    }

    function isAuthorizedDoctor(doctorUid) {
      return isSignedIn() &&
             request.auth.uid == doctorUid &&
             hasUserProfile(request.auth.uid) &&
             getUserDoc(request.auth.uid).role == 'doctor' &&
             getUserDoc(request.auth.uid).doctorUid == doctorUid;
    }

    function isAuthorizedSecretary(doctorUid) {
      return isSignedIn() &&
             hasUserProfile(request.auth.uid) &&
             getUserDoc(request.auth.uid).role == 'secretary' &&
             getUserDoc(request.auth.uid).doctorUid == doctorUid;
    }

    function isAuthorizedForDoctor(doctorUid) {
      return isAuthorizedDoctor(doctorUid) || isAuthorizedSecretary(doctorUid);
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128;
    }

    function isValidUser(data, uid) {
      return data.keys().hasOnly(['uid', 'email', 'role', 'doctorUid', 'createdAt']) &&
             data.uid == uid &&
             isValidId(data.uid) &&
             data.email is string && data.email.size() > 2 && data.email.size() <= 256 &&
             data.role in ['doctor', 'secretary'] &&
             isValidId(data.doctorUid) &&
             data.createdAt is string && data.createdAt.size() <= 64;
    }

    function isSelfDoctorRegistration(data, uid) {
      return isOwner(uid) &&
             isValidUser(data, uid) &&
             data.role == 'doctor' &&
             data.doctorUid == uid &&
             data.email == request.auth.token.email;
    }

    function isInvitedSecretary(data, uid) {
      return isOwner(uid) &&
             isValidUser(data, uid) &&
             data.role == 'secretary' &&
             data.email == request.auth.token.email &&
             exists(invitationPath(data.email)) &&
             get(invitationPath(data.email)).data.email == data.email &&
             get(invitationPath(data.email)).data.doctorUid == data.doctorUid;
    }

    function isLegacyInvitedSecretary(data, uid) {
      let legacyPath = /databases/$(database)/documents/users/$("email:" + data.email);
      return isOwner(uid) &&
             isValidUser(data, uid) &&
             data.role == 'secretary' &&
             data.email == request.auth.token.email &&
             exists(legacyPath) &&
             get(legacyPath).data.email == data.email &&
             get(legacyPath).data.doctorUid == data.doctorUid;
    }

    function isValidInvitation(data) {
      return data.keys().hasOnly(['email', 'role', 'doctorUid', 'createdAt']) &&
             data.email is string && data.email.size() > 2 && data.email.size() <= 256 &&
             data.role == 'secretary' &&
             isValidId(data.doctorUid) &&
             data.createdAt is string && data.createdAt.size() <= 64;
    }

    function isValidDoctorConfig(data) {
      return data.keys().hasOnly([
               'name_fr', 'name_ar', 'specialty_fr', 'specialty_ar', 'order_number',
               'address_fr', 'address_ar', 'phone', 'email', 'matricule_fiscal',
               'code_cnam', 'hours_fr', 'hours_ar', 'footer_fr', 'footer_ar',
               'stamp_text', 'logo_url', 'show_automatic_stamp', 'website'
             ]) &&
             data.name_fr is string && data.name_fr.size() <= 256 &&
             data.name_ar is string && data.name_ar.size() <= 256 &&
             data.specialty_fr is string && data.specialty_fr.size() <= 256 &&
             data.specialty_ar is string && data.specialty_ar.size() <= 256 &&
             data.order_number is string && data.order_number.size() <= 128 &&
             data.address_fr is string && data.address_fr.size() <= 512 &&
             data.address_ar is string && data.address_ar.size() <= 512 &&
             data.phone is string && data.phone.size() <= 64 &&
             (!('email' in data) || (data.email is string && data.email.size() <= 256)) &&
             (!('matricule_fiscal' in data) || (data.matricule_fiscal is string && data.matricule_fiscal.size() <= 128)) &&
             (!('code_cnam' in data) || (data.code_cnam is string && data.code_cnam.size() <= 128)) &&
             (!('hours_fr' in data) || (data.hours_fr is string && data.hours_fr.size() <= 1024)) &&
             (!('hours_ar' in data) || (data.hours_ar is string && data.hours_ar.size() <= 1024)) &&
             (!('footer_fr' in data) || (data.footer_fr is string && data.footer_fr.size() <= 1024)) &&
             (!('footer_ar' in data) || (data.footer_ar is string && data.footer_ar.size() <= 1024)) &&
             (!('stamp_text' in data) || (data.stamp_text is string && data.stamp_text.size() <= 512)) &&
             (!('logo_url' in data) || (data.logo_url is string && data.logo_url.size() <= 2048)) &&
             (!('show_automatic_stamp' in data) || data.show_automatic_stamp is bool) &&
             (!('website' in data) || (data.website is string && data.website.size() <= 256));
    }

    function isValidPatient(data, patientId) {
      return data.keys().hasOnly([
               'id', 'doctorUid', 'name_first', 'name_last', 'birth_date', 'gender',
               'weight', 'allergies', 'is_pregnant', 'has_renal_impairment',
               'has_hepatic_impairment', 'phone', 'current_medications', 'vitals_history'
             ]) &&
             data.id == patientId && isValidId(data.id) &&
             isValidId(data.doctorUid) &&
             data.name_first is string && data.name_first.size() <= 128 &&
             data.name_last is string && data.name_last.size() <= 128 &&
             data.birth_date is string && data.birth_date.size() <= 64 &&
             data.gender in ['M', 'F'] &&
             data.allergies is list && data.allergies.size() <= 50 &&
             (!('weight' in data) || data.weight is number) &&
             (!('is_pregnant' in data) || data.is_pregnant is bool) &&
             (!('has_renal_impairment' in data) || data.has_renal_impairment is bool) &&
             (!('has_hepatic_impairment' in data) || data.has_hepatic_impairment is bool) &&
             (!('phone' in data) || (data.phone is string && data.phone.size() <= 64)) &&
             (!('current_medications' in data) || (data.current_medications is list && data.current_medications.size() <= 100)) &&
             (!('vitals_history' in data) || (data.vitals_history is list && data.vitals_history.size() <= 500));
    }

    function isValidPrescription(data, prescriptionId) {
      return data.keys().hasOnly([
               'id', 'doctorUid', 'patient_id', 'doctor_id', 'prescription_number',
               'prescription_date', 'notes_private', 'print_language_mode', 'status',
               'created_at', 'updated_at', 'signed_at', 'patient_name', 'patient_age_str',
               'patient_gender', 'patient_weight', 'patient_allergies', 'is_cnam_apci'
             ]) &&
             data.id == prescriptionId && isValidId(data.id) &&
             isValidId(data.doctorUid) &&
             data.doctor_id == data.doctorUid &&
             isValidId(data.patient_id) &&
             data.prescription_number is string && data.prescription_number.size() > 0 && data.prescription_number.size() <= 128 &&
             data.prescription_date is string && data.prescription_date.size() <= 64 &&
             data.print_language_mode in ['fr', 'ar', 'bilingual'] &&
             data.status in ['draft', 'signed', 'cancelled'] &&
             data.created_at is string && data.created_at.size() <= 64 &&
             data.updated_at is string && data.updated_at.size() <= 64 &&
             data.patient_name is string && data.patient_name.size() <= 256 &&
             data.patient_age_str is string && data.patient_age_str.size() <= 64 &&
             data.patient_gender in ['M', 'F'] &&
             data.patient_allergies is list && data.patient_allergies.size() <= 50 &&
             (!('notes_private' in data) || (data.notes_private is string && data.notes_private.size() <= 10000)) &&
             (!('patient_weight' in data) || data.patient_weight is number) &&
             (!('is_cnam_apci' in data) || data.is_cnam_apci is bool) &&
             (data.status != 'signed' || ('signed_at' in data && data.signed_at is string && data.signed_at.size() <= 64));
    }

    function isValidPrescriptionItem(data, itemId) {
      return data.keys().hasOnly([
               'id', 'doctorUid', 'prescription_id', 'medicine_id', 'custom_medicine_name',
               'line_order', 'medicine_label', 'dci_name', 'dosage', 'frequency',
               'duration', 'quantity', 'instructions_fr', 'instructions_ar',
               'is_suggestion_used', 'doctor_modified_suggestion', 'created_at', 'updated_at'
             ]) &&
             data.id == itemId && isValidId(data.id) &&
             isValidId(data.doctorUid) &&
             isValidId(data.prescription_id) &&
             data.line_order is int && data.line_order > 0 && data.line_order <= 200 &&
             data.medicine_label is string && data.medicine_label.size() <= 256 &&
             data.dosage is string && data.dosage.size() <= 512 &&
             data.frequency is string && data.frequency.size() <= 512 &&
             data.duration is string && data.duration.size() <= 512 &&
             data.quantity is string && data.quantity.size() <= 256 &&
             data.is_suggestion_used is bool &&
             data.doctor_modified_suggestion is bool &&
             data.created_at is string && data.created_at.size() <= 64 &&
             data.updated_at is string && data.updated_at.size() <= 64 &&
             (!('medicine_id' in data) || (data.medicine_id is string && data.medicine_id.size() <= 128)) &&
             (!('custom_medicine_name' in data) || (data.custom_medicine_name is string && data.custom_medicine_name.size() <= 256)) &&
             (!('dci_name' in data) || (data.dci_name is string && data.dci_name.size() <= 256)) &&
             (!('instructions_fr' in data) || (data.instructions_fr is string && data.instructions_fr.size() <= 2000)) &&
             (!('instructions_ar' in data) || (data.instructions_ar is string && data.instructions_ar.size() <= 2000));
    }

    function parentPrescriptionIsEditable(data) {
      return exists(prescriptionPath(data.prescription_id)) &&
             get(prescriptionPath(data.prescription_id)).data.doctorUid == data.doctorUid &&
             get(prescriptionPath(data.prescription_id)).data.status != 'signed';
    }

    function parentPrescriptionIsCreatedInBatch(data) {
      return !exists(prescriptionPath(data.prescription_id)) &&
             getAfter(prescriptionPath(data.prescription_id)).data.doctorUid == data.doctorUid &&
             getAfter(prescriptionPath(data.prescription_id)).data.id == data.prescription_id;
    }

    function isValidAuditLog(data, auditId) {
      return data.keys().hasOnly([
               'id', 'actor_id', 'doctor_uid', 'action', 'entity_type', 'entity_id',
               'before_json', 'after_json', 'created_at'
             ]) &&
             data.id == auditId && isValidId(data.id) &&
             data.actor_id == request.auth.uid &&
             isAuthorizedForDoctor(data.doctor_uid) &&
             data.action is string && data.action.size() > 0 && data.action.size() <= 128 &&
             data.entity_type is string && data.entity_type.size() > 0 && data.entity_type.size() <= 64 &&
             data.entity_id is string && data.entity_id.size() > 0 && data.entity_id.size() <= 128 &&
             data.created_at == request.time &&
             (!('before_json' in data) || (data.before_json is string && data.before_json.size() <= 20000)) &&
             (!('after_json' in data) || (data.after_json is string && data.after_json.size() <= 20000));
    }

    match /users/{uid} {
      allow read: if isOwner(uid) ||
                     (isAuthorizedDoctor(request.auth.uid) && resource.data.role == 'secretary' && resource.data.doctorUid == request.auth.uid) ||
                     (isSignedIn() && uid == "email:" + request.auth.token.email);
      allow create: if isSelfDoctorRegistration(request.resource.data, uid) ||
                       isInvitedSecretary(request.resource.data, uid) ||
                       isLegacyInvitedSecretary(request.resource.data, uid);
      allow update: if false;
      allow delete: if isOwner(uid) ||
                       (isAuthorizedDoctor(request.auth.uid) && resource.data.role == 'secretary' && resource.data.doctorUid == request.auth.uid) ||
                       (isSignedIn() && uid.matches('email:.*') && resource.data.email == request.auth.token.email);
    }

    match /secretaryInvitations/{email} {
      allow read: if isSignedIn() &&
                     (email == request.auth.token.email || isAuthorizedDoctor(resource.data.doctorUid));
      allow create: if isValidInvitation(request.resource.data) &&
                       request.resource.data.email == email &&
                       isAuthorizedDoctor(request.resource.data.doctorUid);
      allow update: if false;
      allow delete: if isSignedIn() &&
                       (resource.data.email == request.auth.token.email || isAuthorizedDoctor(resource.data.doctorUid));
    }

    match /doctorConfigs/{doctorUid} {
      allow read: if isAuthorizedForDoctor(doctorUid);
      allow create, update: if isAuthorizedDoctor(doctorUid) && isValidDoctorConfig(request.resource.data);
      allow delete: if isAuthorizedDoctor(doctorUid);
    }

    match /patients/{patientId} {
      allow read: if isAuthorizedForDoctor(resource.data.doctorUid);
      allow create: if isAuthorizedForDoctor(request.resource.data.doctorUid) &&
                       isValidPatient(request.resource.data, patientId);
      allow update: if isAuthorizedForDoctor(resource.data.doctorUid) &&
                       request.resource.data.doctorUid == resource.data.doctorUid &&
                       request.resource.data.id == resource.data.id &&
                       isValidPatient(request.resource.data, patientId);
      allow delete: if isAuthorizedDoctor(resource.data.doctorUid);
    }

    match /prescriptions/{prescriptionId} {
      allow read: if isAuthorizedDoctor(resource.data.doctorUid);
      allow create: if isAuthorizedDoctor(request.resource.data.doctorUid) &&
                       exists(patientPath(request.resource.data.patient_id)) &&
                       get(patientPath(request.resource.data.patient_id)).data.doctorUid == request.resource.data.doctorUid &&
                       isValidPrescription(request.resource.data, prescriptionId);
      allow update: if isAuthorizedDoctor(resource.data.doctorUid) &&
                       resource.data.status != 'signed' &&
                       request.resource.data.doctorUid == resource.data.doctorUid &&
                       request.resource.data.patient_id == resource.data.patient_id &&
                       (request.resource.data.doctor_id == resource.data.doctor_id ||
                        (resource.data.doctor_id == 'doc-current' && request.resource.data.doctor_id == resource.data.doctorUid)) &&
                       request.resource.data.id == resource.data.id &&
                       request.resource.data.created_at == resource.data.created_at &&
                       request.resource.data.prescription_number == resource.data.prescription_number &&
                       isValidPrescription(request.resource.data, prescriptionId);
      allow delete: if isAuthorizedDoctor(resource.data.doctorUid) && resource.data.status != 'signed';
    }

    match /prescriptionItems/{prescriptionItemId} {
      allow read: if isAuthorizedDoctor(resource.data.doctorUid);
      allow create: if isAuthorizedDoctor(request.resource.data.doctorUid) &&
                       isValidPrescriptionItem(request.resource.data, prescriptionItemId) &&
                       (parentPrescriptionIsEditable(request.resource.data) || parentPrescriptionIsCreatedInBatch(request.resource.data));
      allow update: if isAuthorizedDoctor(resource.data.doctorUid) &&
                       request.resource.data.doctorUid == resource.data.doctorUid &&
                       request.resource.data.prescription_id == resource.data.prescription_id &&
                       request.resource.data.id == resource.data.id &&
                       parentPrescriptionIsEditable(resource.data) &&
                       isValidPrescriptionItem(request.resource.data, prescriptionItemId);
      allow delete: if isAuthorizedDoctor(resource.data.doctorUid) && parentPrescriptionIsEditable(resource.data);
    }

    match /auditLogs/{auditId} {
      allow read: if isSignedIn() && isAuthorizedDoctor(resource.data.doctor_uid);
      allow create: if isSignedIn() && isValidAuditLog(request.resource.data, auditId);
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
