{
  "entities": {
    "user": {
      "title": "User Profile",
      "description": "User account detail indicating role (doctor/secretary) and linking secretary to doctor",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["doctor", "secretary"] },
        "doctorUid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "doctorUid", "createdAt"]
    },
    "doctorConfig": {
      "title": "Doctor Configuration",
      "description": "Information about the doctor's practice, contact info, and printing options",
      "type": "object",
      "properties": {
        "name_fr": { "type": "string" },
        "name_ar": { "type": "string" },
        "specialty_fr": { "type": "string" },
        "specialty_ar": { "type": "string" },
        "order_number": { "type": "string" },
        "address_fr": { "type": "string" },
        "address_ar": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "matricule_fiscal": { "type": "string" },
        "code_cnam": { "type": "string" },
        "hours_fr": { "type": "string" },
        "hours_ar": { "type": "string" },
        "footer_fr": { "type": "string" },
        "footer_ar": { "type": "string" },
        "stamp_text": { "type": "string" },
        "logo_url": { "type": "string" },
        "show_automatic_stamp": { "type": "boolean" }
      },
      "required": ["name_fr", "name_ar", "specialty_fr", "specialty_ar", "order_number", "address_fr", "address_ar", "phone"]
    },
    "patient": {
      "title": "Patient Record",
      "description": "Medical and contact records of a patient",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "doctorUid": { "type": "string" },
        "name_first": { "type": "string" },
        "name_last": { "type": "string" },
        "birth_date": { "type": "string" },
        "gender": { "type": "string", "enum": ["M", "F"] },
        "weight": { "type": "number" },
        "allergies": { "type": "array" },
        "is_pregnant": { "type": "boolean" },
        "has_renal_impairment": { "type": "boolean" },
        "has_hepatic_impairment": { "type": "boolean" },
        "phone": { "type": "string" },
        "current_medications": { "type": "array" }
      },
      "required": ["id", "doctorUid", "name_first", "name_last", "birth_date", "gender", "allergies"]
    },
    "prescription": {
      "title": "Prescription",
      "description": "A medical prescription written for a patient",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "doctorUid": { "type": "string" },
        "patient_id": { "type": "string" },
        "doctor_id": { "type": "string" },
        "prescription_number": { "type": "string" },
        "prescription_date": { "type": "string" },
        "notes_private": { "type": "string" },
        "print_language_mode": { "type": "string", "enum": ["fr", "ar", "bilingual"] },
        "status": { "type": "string", "enum": ["draft", "signed", "cancelled"] },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" },
        "signed_at": { "type": "string" },
        "patient_name": { "type": "string" },
        "patient_age_str": { "type": "string" },
        "patient_gender": { "type": "string", "enum": ["M", "F"] },
        "patient_weight": { "type": "number" },
        "patient_allergies": { "type": "array" },
        "is_cnam_apci": { "type": "boolean" }
      },
      "required": [
        "id",
        "doctorUid",
        "patient_id",
        "doctor_id",
        "prescription_number",
        "prescription_date",
        "print_language_mode",
        "status",
        "created_at",
        "updated_at",
        "patient_name",
        "patient_age_str",
        "patient_gender",
        "patient_allergies"
      ]
    },
    "prescriptionItem": {
      "title": "Prescription Item",
      "description": "An individual medicine line inside a prescription",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "doctorUid": { "type": "string" },
        "prescription_id": { "type": "string" },
        "medicine_id": { "type": "string" },
        "custom_medicine_name": { "type": "string" },
        "line_order": { "type": "number" },
        "medicine_label": { "type": "string" },
        "dci_name": { "type": "string" },
        "dosage": { "type": "string" },
        "frequency": { "type": "string" },
        "duration": { "type": "string" },
        "quantity": { "type": "string" },
        "instructions_fr": { "type": "string" },
        "instructions_ar": { "type": "string" },
        "is_suggestion_used": { "type": "boolean" },
        "doctor_modified_suggestion": { "type": "boolean" },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" }
      },
      "required": [
        "id",
        "doctorUid",
        "prescription_id",
        "line_order",
        "medicine_label",
        "dosage",
        "frequency",
        "duration",
        "quantity",
        "is_suggestion_used",
        "doctor_modified_suggestion",
        "created_at",
        "updated_at"
      ]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "user",
      "description": "Collection of user registration roles and relations"
    },
    "/doctorConfigs/{doctorUid}": {
      "schema": "doctorConfig",
      "description": "Collection of configurations for doctors"
    },
    "/patients/{patientId}": {
      "schema": "patient",
      "description": "Collection of patient health and contact files"
    },
    "/prescriptions/{prescriptionId}": {
      "schema": "prescription",
      "description": "Collection of prescription dossiers"
    },
    "/prescriptionItems/{prescriptionItemId}": {
      "schema": "prescriptionItem",
      "description": "Collection of individual prescription medicine lines"
    }
  }
}
